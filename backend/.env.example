APP_NAME=AcaFund
ENV=development

# Generate with: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# PostgreSQL — matches docker-compose defaults
DATABASE_URL=postgresql://acafund:acafund@postgres:5432/acafund

# Monnify
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=3412200072
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Anthropic (optional, for AI features)
ANTHROPIC_API_KEY=

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Expense governance
EXPENSE_APPROVAL_THRESHOLD=50000
